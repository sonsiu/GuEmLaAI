@model dynamic
@{
    Layout = null;
    string resetUrl = Model.VerificationUrl ?? "#";
    string displayName = Model.DisplayName ?? Model.Email ?? "User";
}

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reset your password</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
            padding: 0;
            background: #f4f4f7;
            color: #333;
        }

        .container {
            max-width: 600px;
            margin: 30px auto;
            background: #ffffff;
            border-radius: 6px;
            overflow: hidden;
            box-shadow: 0 2px 6px rgba(0,0,0,0.06);
        }

        .header {
            padding: 20px;
            text-align: center;
            background: #0b79d0;
            color: #fff;
        }

        .content {
            padding: 24px;
            line-height: 1.5;
        }

        .button {
            display: inline-block;
            padding: 12px 22px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
        }

        .btn-reset {
            background: #d97706;
            color: #ffffff;
        }

        .muted {
            color: #6b7280;
            font-size: 13px;
        }

        .pre {
            word-break: break-all;
            font-family: monospace;
            background: #f1f5f9;
            padding: 10px;
            border-radius: 4px;
            font-size: 13px;
        }

        .footer {
            padding: 16px 24px;
            font-size: 12px;
            color: #909090;
            text-align: center;
        }

        @@media (max-width:480px) {
            .container {
                margin: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="container" role="article" aria-roledescription="email">
        <div class="header">
            <h1 style="margin:0; font-size:20px;">Reset Your Password</h1>
        </div>

        <div class="content">
            <p>Hi <strong>@displayName</strong>,</p>

            <p>We received a request to reset your password for your GuEmLaAI account. If you made this request, click the button below to set a new password.</p>

            <p style="text-align:center; margin:22px 0;">
                <a href="@resetUrl" class="button btn-reset" target="_blank" rel="noopener">Reset Password</a>
            </p>

            <p class="muted" style="text-align:center; margin-top:0;">
                This link will expire in 24 hours for your security.
            </p>

            <hr />

            <p class="muted">If the button above doesn’t work, copy and paste this URL into your browser:</p>
            <p class="pre"><a href="@resetUrl" target="_blank" rel="noopener">@resetUrl</a></p>

            <p class="muted">If you did not request a password reset, please ignore this email. Your account is still secure.</p>

            <p>Thanks,<br />The GuEmLaAI Team</p>
        </div>

        <div class="footer">
            <div>GuEmLaAI • <span>@(System.DateTime.UtcNow.ToString("yyyy"))</span></div>
        </div>
    </div>
</body>
</html>
